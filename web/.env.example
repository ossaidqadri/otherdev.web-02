# Canvas API
CANVAS_API_URL=https://client5.otherdev.com/canvas/v1/api/

# Google Service Account Credentials
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# Google Sheets
GOOGLE_SHEET_ID=your-google-sheet-id
CANVAS_API_KEY=
CANVAS_PROJECT_ID=

# Gmail
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password
GMAIL_RECIPIENTS=email1@gmail.com,email2@gmail.com

# Groq API Configuration
GROQ_API_KEY=your-groq-api-key-here

# Supabase Configuration
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# HuggingFace Configuration
HUGGINGFACE_API_KEY=your-huggingface-api-key-here

# Mastra Configuration
MASTRA_ENV=development
MASTRA_POSTGRES_CONNECTION_STRING=postgresql://postgres:[password]@[host]:5432/postgres
MASTRA_LOG_LEVEL=info

# RAG Configuration
RAG_SIMILARITY_THRESHOLD=0.1
RAG_MATCH_COUNT=10
RAG_MAX_MESSAGE_LENGTH=500
