# Site Configuration
NEXT_PUBLIC_SITE_URL=https://otherdev.com
NEXT_PUBLIC_API_URL=http://localhost:3000

# Auth Configuration
NEXT_PUBLIC_AUTH_BASE_URL=https://lxauthentication.deployments.otherdev.com
NEXT_PUBLIC_AUTH_GOOGLE_CLIENT_ID=your-google-client-id

# Canvas API
CANVAS_API_URL=https://client5.otherdev.com/canvas/v1/api/
CANVAS_API_KEY=
CANVAS_PROJECT_ID=

# Payload CMS
PAYLOAD_API_URL=https://canvas.otherdev.com

# Google Service Account Credentials
GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# Google Sheets
GOOGLE_SHEET_ID=your-google-sheet-id

# Gmail
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-16-character-app-password
GMAIL_RECIPIENTS=email1@gmail.com,email2@gmail.com

# Groq API Configuration
GROQ_API_KEY=your-groq-api-key-here

# Tavily Web Search (for general chat with web grounding)
TAVILY_API_KEY=your-tavily-api-key-here

# Mistral API (document processing)
MISTRAL_API_KEY=your-mistral-api-key-here

# MiniMax API (fallback LLM)
MINIMAX_API_KEY=your-minimax-api-key-here

# Voyage AI (embeddings)
VOYAGE_API_KEY=your-voyage-api-key-here

# Firebase Configuration (Service Account)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour private key here\n-----END PRIVATE KEY-----\n"

# Upstash Redis (chat message caching)
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# RAG / Cache Configuration
RAG_SIMILARITY_THRESHOLD=0.1
RAG_MATCH_COUNT=5
RAG_MAX_MESSAGE_LENGTH=500
CHAT_HISTORY_TTL_SECONDS=1209600
RAG_RETRIEVAL_CACHE_TTL_SECONDS=21600
CHAT_RESPONSE_CACHE_TTL_SECONDS=86400
RAG_KB_VERSION=
