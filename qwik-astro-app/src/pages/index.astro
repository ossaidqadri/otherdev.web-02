---
import Layout from '../layouts/Layout.astro'
import { Navigation } from '../components/navigation'
import { ProjectCard } from '../components/project-card'
import { Footer } from '../components/footer'
import { projects } from '../lib/projects'
import { playlistsAndImages } from '../lib/playlists-and-images'
import { shuffle } from '../lib/utils'

const title = 'Other Dev'
const description = 'Digital platforms for pioneering creatives'

// Create projects with extra media images for grid variety
const projectsWithExtraImages = projects.flatMap(project => {
  const cards = [project]
  if (project.media && project.media.length >= 2) {
    cards.push({
      ...project,
      id: `${project.id}-media-2`,
      image: project.media[1],
    })
  }
  return cards
})

// Combine and shuffle
const data = shuffle([...playlistsAndImages, ...projectsWithExtraImages])
---

<Layout title={title} description={description}>
  <Navigation qwik:visible />
  <main class="container mx-auto px-3 pr-3 md:pr-[8%] lg:pr-[15%] pt-[60px] pb-12">
    <div class="grid grid-cols-12 mb-8 mt-[60px]">
      <p class="text-[#686868] text-[11px] leading-[14px] font-normal col-span-12 sm:col-span-8 md:col-span-7 lg:col-span-6">
        otherdev produces digital platforms for pioneering creatives. Based in Karachi City, we
        are a full-service web development and design studio specializing in the fashion and
        design fields.
      </p>
    </div>
    <div class="mt-[30px] grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-[12px] gap-y-[15px]">
      {data.map((item, index) => (
        item.isPlaylistOrImage ? (
          <ProjectCard
            qwik:visible
            title={item.title}
            slug={item.url ?? ''}
            image={item.image}
            description={item.description}
            variant="broll"
            priority={index < 8}
          />
        ) : (
          <ProjectCard
            qwik:visible
            title={item.title}
            slug={item.slug}
            image={item.image}
            description={item.description}
            variant="home"
            priority={index < 8}
          />
        )
      ))}
    </div>
    <Footer qwik:visible />
  </main>
</Layout>
